{
  "name": "bitbadgesjs-sdk",
  "description": "SDK for BitBadges development - Compatible with BitBadges v12 (SDK 0.18.x), v13 (SDK 0.19.x), v14 (SDK 0.20.x), v20 (SDK 0.25.x), v21 (SDK 0.26.x), v22 (SDK 0.27.x), v23 (SDK 0.28.x), v24 (SDK 0.29.x), and v25 (SDK 0.30.x)",
  "version": "0.33.0",
  "license": "MIT",
  "keywords": [
    "bitbadges",
    "blockchain",
    "sdk",
    "typescript",
    "cosmos",
    "badges",
    "nft"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bitbadges/bitbadgesjs.git"
  },
  "homepage": "https://github.com/bitbadges/bitbadgesjs#readme",
  "bugs": {
    "url": "https://github.com/bitbadges/bitbadgesjs/issues"
  },
  "eslintIgnore": [
    "src/proto/**/*.ts"
  ],
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "bin": {
    "bitbadges-cli": "./dist/cjs/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "alias": "tsc-alias -p tsconfig.build.json && tsc-alias -p tsconfig-esm.build.json",
    "build": "rm -rf dist && tsc --build tsconfig.build.json && tsc --build tsconfig-esm.build.json && bun run alias && bun run fixup && bun run dep-check",
    "routes-check": "ts-node ./scripts/check_routes_consistency.ts ../../../bitbadges-indexer/src/indexer.ts  ./openapitypes-helpers/routes.yaml",
    "clean": "tsc --build tsconfig.build.json --clean  && shx rm -rf coverage *.log junit.xml dist && jest --clearCache",
    "fixup": "./scripts/fixup.sh",
    "test": "jest ./src/**/*.spec.ts --setupFiles ./jest.setup.js",
    "test:unit": "jest test/unit",
    "test:integration": "jest test/unit",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --ci --reporters='jest-junit'",
    "coverage": "jest --coverage",
    "dev": "ts-node-dev -r tsconfig-paths/register src/index.ts",
    "start": "node dist/index.js",
    "format": "prettier --write './**/*.{js,jsx,ts,tsx,css,md,json}' --config ./.prettierrc",
    "format-ci": "prettier --write './**/*.{js,jsx,ts,tsx,css,md,json}' --config ./.prettierrc-ci.json",
    "prepare": "ts-patch install && typia patch",
    "dep-check": "madge --circular ./src/index.ts --warning --ts-config ./tsconfig.json --exclude 'api-indexer/docs-types/interfaces.ts|interfaces/badges/*|interfaces/types/*'",
    "generate-api-routes": "bun scripts/generate-api-routes.ts",
    "publish-w-docs": "bash ./scripts/check_and_publish.sh"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@bufbuild/buf": "^1.67.0",
    "@bufbuild/protoc-gen-es": "^1.10.1",
    "@types/jest": "^27.5.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^16.18.126",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "babel-jest": "^29.7.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^6.6.0",
    "fs-extra": "^11.3.4",
    "husky": "^7.0.4",
    "jest": "^29.7.0",
    "jest-junit": "^13.0.0",
    "js-yaml": "^4.1.0",
    "madge": "^8.0.0",
    "markdownlint-cli": "^0.47.0",
    "merkletreejs": "^0.3.11",
    "path": "^0.12.7",
    "prettier": "^3.8.1",
    "shx": "^0.3.4",
    "ts-jest": "^29.4.9",
    "ts-jest-resolver": "^2.0.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^1.1.8",
    "ts-patch": "^3.3.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^3.15.0",
    "tsoa": "^6.6.0",
    "tsup": "^8.5.1",
    "typescript": "~5.8.3"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^1.10.1",
    "axios": "^1.14.0",
    "bech32": "^2.0.0",
    "commander": "^14.0.3",
    "crypto-addr-codec": "^0.1.7",
    "ethers": "^6.13.4",
    "sha3": "^2.1.4",
    "typia": "^8.0.2",
    "web3-validator": "^2.0.6"
  }
}
